symbol = "{{ .Symbol }}"
id = "default-{{ .SymbolLower }}"
rule_chain = "configs/rules/default.json"

[risk_management]
# 单笔风险占比（占账户权益百分比）
risk_per_trade_pct = {{ .RiskPerTradePct }}
# 最大可用资金占比
max_invest_pct = {{ .MaxInvestPct }}
# 最大有效杠杆
max_leverage = {{ .MaxLeverage }}
# Grade → 风险系数（Grade 由 setup_quality 自动评定）
grade_3_factor = 1.0
grade_2_factor = 0.7
grade_1_factor = 0.4
# 入场模式：orderbook / atr_offset / market
entry_mode = "{{ .EntryMode }}"
orderbook_depth = 5
entry_offset_atr = 0.1
breakeven_fee_pct = 0.0
slippage_buffer_pct = 0.0005

[risk_management.risk_strategy]
mode = "llm"

[risk_management.initial_exit]
policy = "atr_structure_v1"
structure_interval = "auto"

[risk_management.initial_exit.params]
stop_atr_multiplier = 2
stop_min_distance_pct = 0.008
take_profit_rr = [1, 2]
take_profit_ratios = [0.6, 0.4]

[risk_management.tighten_atr]
structure_threatened = 1.2
tp1_atr = 0.8
tp2_atr = 1.5
min_tp_distance_pct = 0.006
min_tp_gap_pct = 0.005
min_update_interval_sec = {{ .TightenMinUpdateIntervalSec }}

# Gate 决策阈值（决定"做不做"）
# quality_threshold: 建仓质量最低要求（0.20 激进 / 0.35 默认 / 0.55 保守）
# edge_threshold: 执行价值最低要求（0.05 激进 / 0.10 默认 / 0.20 保守）
[risk_management.gate]
quality_threshold = 0.35
edge_threshold = 0.10

# Sieve 仓位缩放（Gate 放行后控制"做多大"）
[risk_management.sieve]
min_size_factor = 0.35
default_gate_action = "ALLOW"
default_size_factor = 1.0

[[risk_management.sieve.rows]]
mechanics_tag = "fuel_ready"
liq_confidence = "high"
crowding_align = false
gate_action = "ALLOW"
size_factor = 1.0
reason_code = "FUEL_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "fuel_ready"
liq_confidence = "low"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.7
reason_code = "FUEL_LOW"

[[risk_management.sieve.rows]]
mechanics_tag = "neutral"
liq_confidence = "high"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.7
reason_code = "NEUTRAL_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "neutral"
liq_confidence = "low"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.5
reason_code = "NEUTRAL_LOW"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_long"
liq_confidence = "high"
crowding_align = true
gate_action = "ALLOW"
size_factor = 0.4
reason_code = "CROWD_LONG_ALIGN_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_long"
liq_confidence = "low"
crowding_align = true
gate_action = "ALLOW"
size_factor = 0.5
reason_code = "CROWD_LONG_ALIGN_LOW"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_short"
liq_confidence = "high"
crowding_align = true
gate_action = "ALLOW"
size_factor = 0.4
reason_code = "CROWD_SHORT_ALIGN_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_short"
liq_confidence = "low"
crowding_align = true
gate_action = "ALLOW"
size_factor = 0.5
reason_code = "CROWD_SHORT_ALIGN_LOW"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_long"
liq_confidence = "high"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.35
reason_code = "CROWD_LONG_COUNTER_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_long"
liq_confidence = "low"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.5
reason_code = "CROWD_LONG_COUNTER_LOW"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_short"
liq_confidence = "high"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.35
reason_code = "CROWD_SHORT_COUNTER_HIGH"

[[risk_management.sieve.rows]]
mechanics_tag = "crowded_short"
liq_confidence = "low"
crowding_align = false
gate_action = "ALLOW"
size_factor = 0.5
reason_code = "CROWD_SHORT_COUNTER_LOW"
